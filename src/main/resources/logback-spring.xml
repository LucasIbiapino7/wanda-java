<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- OTel Appender — envia logs ao Collector em qualquer profile -->
    <appender name="OTEL"
              class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
        <captureExperimentalAttributes>false</captureExperimentalAttributes>
        <captureKeyValuePairAttributes>true</captureKeyValuePairAttributes>
    </appender>

    <!-- Appender que vincula logs como eventos do span no Jaeger -->
    <appender name="OTEL_SPAN"
              class="com.cosmo.wanda_web.config.OtelLogAppender"/>

    <!-- DEV — texto legível no terminal -->
    <springProfile name="dev,default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%X{trace_id},%X{span_id}] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="OTEL"/>
            <appender-ref ref="OTEL_SPAN"/>
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- PROD — JSON -->
    <springProfile name="prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>
        <root level="INFO">
            <appender-ref ref="OTEL"/>
            <appender-ref ref="OTEL_SPAN"/>
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>